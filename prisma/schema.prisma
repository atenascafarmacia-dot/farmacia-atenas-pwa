generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum OrderStatus {
  PENDIENTE
  PROCESANDO
  COMPLETADA
  CANCELADA
}

model Product {
  id                   String      @id @default(cuid())
  name                 String
  description          String?
  price                Float
  stock                Int         @default(0)
  imageUrl             String?
  category             String
  requiresPrescription Boolean     @default(false)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  orderItems           OrderItem[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id        String      @id @default(cuid())
  code      String      @unique
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  status    OrderStatus @default(PENDIENTE)
  total     Float
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
}
